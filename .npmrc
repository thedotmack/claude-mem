legacy-peer-deps=true
# Pre-approve install scripts for the native/tree-sitter deps so npm 11.16+/v12
# does not abort the marketplace install with EALLOWSCRIPTS. This is the .npmrc
# complement to the "allowScripts" field in package.json — it covers the
# git-clone marketplace path (npm strips .npmrc from published tarballs, so the
# package.json field is what lands via the npx-install path). This is the
# CONFIG-FILE form of allow-scripts, which npm accepts, NOT the bare
# `--allow-scripts` CLI flag, which npm rejects in project-scoped installs.
# Keep in sync with scripts/postinstall-allowlist.js (enforced by CI).
allow-scripts=tree-sitter-cli,tree-sitter,tree-sitter-c,tree-sitter-cpp,tree-sitter-go,tree-sitter-java,tree-sitter-javascript,tree-sitter-python,tree-sitter-ruby,tree-sitter-rust,tree-sitter-typescript,tree-sitter-kotlin,tree-sitter-swift,tree-sitter-php,tree-sitter-scala,tree-sitter-bash,tree-sitter-haskell,tree-sitter-css,tree-sitter-scss,@tree-sitter-grammars/tree-sitter-lua,@tree-sitter-grammars/tree-sitter-zig,@tree-sitter-grammars/tree-sitter-toml,@tree-sitter-grammars/tree-sitter-yaml,@tree-sitter-grammars/tree-sitter-markdown,@derekstride/tree-sitter-sql,esbuild,@biomejs/biome,better-sqlite3
