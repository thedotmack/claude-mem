{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node ./cursor-hooks/hook-runner.js session-init"
      },
      {
        "command": "node ./cursor-hooks/hook-runner.js context-inject"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node ./cursor-hooks/hook-runner.js save-observation"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node ./cursor-hooks/hook-runner.js save-observation"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node ./cursor-hooks/hook-runner.js save-file-edit"
      }
    ],
    "stop": [
      {
        "command": "node ./cursor-hooks/hook-runner.js session-summary"
      }
    ]
  }
}

