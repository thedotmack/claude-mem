# Copy to external-memory.env and change the password before starting
# docker-compose.external-memory.yml.
POSTGRES_USER=claude_mem
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_DB=claude_mem
VALKEY_PASSWORD=change-this-valkey-password
VALKEY_MAXMEMORY=256mb

# Bound to 127.0.0.1 by docker-compose.external-memory.yml.
PGVECTOR_HOST_PORT=15432
VALKEY_HOST_PORT=16379
