#!/bin/bash
# claude-mem-sync — Bidirectional sync with WAL-safe database transfers
#
# v2: Replaces JSON export/import with content_hash dedup merge + WAL checkpoint.
# Prevents FTS5 corruption by checkpointing WAL before transfer and stopping
# the remote worker during push.
#
# Usage:
#   claude-mem-sync push  <remote-host>   # merge remote→local, then push DB
#   claude-mem-sync pull  <remote-host>   # pull and merge remote obs into local
#   claude-mem-sync sync  <remote-host>   # bidirectional (pull + push)
#   claude-mem-sync status <remote-host>  # compare counts
#
# Prerequisites:
#   - SSH access to remote host (key-based auth recommended)
#   - Bun installed on the local machine (uses bun:sqlite for content_hash merge)
#   - claude-mem installed on both machines (~/.claude-mem/claude-mem.db)
#   - Remote worker managed via systemd (claude-mem-worker.service)
#
# Environment variables:
#   CLAUDE_MEM_DB         Local database path (default: ~/.claude-mem/claude-mem.db)
#   CLAUDE_MEM_REMOTE_DB  Remote database path (default: ~/.claude-mem/claude-mem.db)
#   CLAUDE_MEM_SSH_KEY    SSH key path (optional, uses default if unset)
#   CLAUDE_MEM_SSH_OPTS   Extra SSH options (default: -o ConnectTimeout=5)

set -euo pipefail

LOCAL_DB="${CLAUDE_MEM_DB:-$HOME/.claude-mem/claude-mem.db}"
COMMAND="${1:?Usage: claude-mem-sync <push|pull|sync|status> <remote-host>}"
REMOTE_HOST="${2:?Missing remote host. Usage: claude-mem-sync $COMMAND <remote-host>}"
REMOTE_DB="${CLAUDE_MEM_REMOTE_DB:-.claude-mem/claude-mem.db}"
TMPDIR="/tmp/claude-mem-sync-$$"

SSH_KEY_OPT=""
if [ -n "${CLAUDE_MEM_SSH_KEY:-}" ]; then
  SSH_KEY_OPT="-i $CLAUDE_MEM_SSH_KEY"
fi
SSH_OPTS="${CLAUDE_MEM_SSH_OPTS:--o ConnectTimeout=5}"
SSH_CMD="ssh $SSH_KEY_OPT $SSH_OPTS"

mkdir -p "$TMPDIR"
trap "rm -rf $TMPDIR" EXIT

# Merge new observations from a remote DB into the local DB using content_hash dedup.
# Only imports observations whose content_hash doesn't exist locally.
merge_remote_obs() {
  local remote_db_file="$1"
  bun -e "
const local = require('bun:sqlite').Database.open('$LOCAL_DB');
const remote = require('bun:sqlite').Database.open('$remote_db_file', {readonly: true});
const localHashes = new Set(
  local.query('SELECT content_hash FROM observations WHERE content_hash IS NOT NULL')
    .all().map(r => r.content_hash)
);
const remoteObs = remote.query('SELECT * FROM observations WHERE content_hash IS NOT NULL').all();
let imported = 0;
const insert = local.prepare(
  'INSERT OR IGNORE INTO observations (memory_session_id, project, text, type, title, subtitle, ' +
  'facts, narrative, concepts, files_read, files_modified, prompt_number, discovery_tokens, ' +
  'created_at, created_at_epoch, content_hash, status, relevance_count, generated_by_model) ' +
  'VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)'
);
for (const o of remoteObs) {
  if (!localHashes.has(o.content_hash)) {
    insert.run(
      o.memory_session_id, o.project, o.text, o.type, o.title, o.subtitle,
      o.facts, o.narrative, o.concepts, o.files_read, o.files_modified,
      o.prompt_number, o.discovery_tokens, o.created_at, o.created_at_epoch,
      o.content_hash, o.status, o.relevance_count || 0, o.generated_by_model
    );
    imported++;
  }
}
remote.close();
console.log(imported);
" 2>/dev/null
}

# Checkpoint WAL to merge all pending writes into the main DB file.
# This ensures the .db file is complete and self-contained for transfer.
checkpoint_local_wal() {
  bun -e "require('bun:sqlite').Database.open('$LOCAL_DB').run('PRAGMA wal_checkpoint(TRUNCATE)')" 2>/dev/null
}

# Count observations and summaries in a database
count_db() {
  local db="$1"
  bun -e "
const db = require('bun:sqlite').Database.open('$db', {readonly: true});
const obs = db.query('SELECT COUNT(*) as c FROM observations').get().c;
const sums = db.query('SELECT COUNT(*) as c FROM session_summaries').get().c;
const last = db.query('SELECT MAX(created_at) as m FROM observations').get().m || 'empty';
console.log(obs + ' obs, ' + sums + ' sums (last: ' + last.slice(0,19) + ')');
db.close();
" 2>/dev/null
}

do_pull() {
  echo "=== Pull: $REMOTE_HOST → local (merge by content_hash) ==="
  local remote_db_file="$TMPDIR/remote.db"

  # Download remote DB
  $SSH_CMD "$REMOTE_HOST" "cat ~/$REMOTE_DB" > "$remote_db_file" 2>/dev/null

  if [ ! -s "$remote_db_file" ]; then
    echo "Warning: Remote DB is empty or download failed"
    return 1
  fi

  # Merge new observations
  local imported
  imported=$(merge_remote_obs "$remote_db_file")
  echo "Merged $imported new observations from $REMOTE_HOST"
  rm -f "$remote_db_file"
}

do_push() {
  echo "=== Push: local → $REMOTE_HOST (WAL-safe) ==="

  # 1. Checkpoint local WAL (atomic DB file)
  checkpoint_local_wal

  # 2. Stop remote worker to prevent FTS corruption during write
  $SSH_CMD "$REMOTE_HOST" "systemctl --user stop claude-mem-worker 2>/dev/null; rm -f ~/$REMOTE_DB-shm ~/$REMOTE_DB-wal ~/.claude-mem/worker.pid" 2>/dev/null || true

  # 3. Push clean DB
  scp $SSH_KEY_OPT $SSH_OPTS "$LOCAL_DB" "$REMOTE_HOST:~/$REMOTE_DB" 2>/dev/null

  # 4. Restart remote worker
  $SSH_CMD "$REMOTE_HOST" "systemctl --user start claude-mem-worker" 2>/dev/null || true

  echo "Pushed $(count_db "$LOCAL_DB") to $REMOTE_HOST"
}

case "$COMMAND" in
  pull)
    do_pull
    ;;
  push)
    do_push
    ;;
  sync)
    echo "=== Bidirectional sync with $REMOTE_HOST ==="
    do_pull
    do_push
    echo "=== Status ==="
    echo "Local: $(count_db "$LOCAL_DB")"
    echo "Remote: $($SSH_CMD "$REMOTE_HOST" "bun -e \"const db=require('bun:sqlite').Database.open('\$HOME/$REMOTE_DB',{readonly:true});const o=db.query('SELECT COUNT(*) as c FROM observations').get().c;const s=db.query('SELECT COUNT(*) as c FROM session_summaries').get().c;console.log(o+' obs, '+s+' sums');db.close()\"" 2>/dev/null || echo "unknown")"
    ;;
  status)
    echo "=== Local ==="
    count_db "$LOCAL_DB"
    echo "=== Remote ($REMOTE_HOST) ==="
    $SSH_CMD "$REMOTE_HOST" "bun -e \"const db=require('bun:sqlite').Database.open('\$HOME/$REMOTE_DB',{readonly:true});const o=db.query('SELECT COUNT(*) as c FROM observations').get().c;const s=db.query('SELECT COUNT(*) as c FROM session_summaries').get().c;const l=db.query('SELECT MAX(created_at) as m FROM observations').get().m||'empty';console.log(o+' obs, '+s+' sums (last: '+l.slice(0,19)+')');db.close()\"" 2>/dev/null || echo "Remote DB query failed"
    ;;
  *)
    echo "Usage: claude-mem-sync <push|pull|sync|status> <remote-host>"
    exit 1
    ;;
esac
